{
  "name": "ai-interviewer",
  "version": "1.0.0",
  "description": "AI-powered interview practice application with Lemonade SDK integration",
  "main": "src/electron_app/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "dev:react": "vite",
    "dev:electron": "electron .",
    "build": "vite build",
    "build:electron": "electron-builder",
    "test": "jest",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx"
  },
  "keywords": [
    "interview",
    "ai",
    "practice",
    "electron",
    "lemonade-sdk"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "openai": "^4.28.0",
    "axios": "^1.6.5",
    "form-data": "^4.0.0",
    "electron-store": "^8.1.0",
    "better-sqlite3": "^9.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "zustand": "^4.4.7",
    "date-fns": "^3.0.6",
    "lucide-react": "^0.312.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.11",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.33",
    "autoprefixer": "^10.4.17",
    "typescript": "^5.3.3",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/better-sqlite3": "^7.6.8",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.11.5",
    "jest": "^29.7.0",
    "eslint": "^8.56.0"
  },
  "build": {
    "appId": "com.interviewer.app",
    "productName": "AI Interviewer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
